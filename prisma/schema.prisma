generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  SUPER_ADMIN
  MEMBER
}

enum CoupleMemberRole {
  OWNER
  PARTNER
}

enum CoupleMemberStatus {
  INVITED
  ACTIVE
  SUSPENDED
}

model User {
  id                    String          @id @default(cuid())
  name                  String?
  email                 String?         @unique
  emailVerified         DateTime?
  image                 String?
  role                  UserRole        @default(MEMBER)
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt
  accounts              Account[]
  sessions              Session[]
  memberships           CoupleMember[]
  createdMemories       UploadedImage[] @relation("MemoryCreator")
  createdPuzzles        PuzzleImages[]  @relation("PuzzleCreator")
  createdJourneyEntries JourneyEntry[]  @relation("JourneyCreator")
  updatedLoveNotes      LoveNote[]      @relation("NoteEditor")
  auditLogs             AuditLog[]      @relation("AuditActor")
}

model Couple {
  id             String           @id @default(cuid())
  name           String
  slug           String           @unique
  passcodeHash   String
  startDate      DateTime?
  maxMemories    Int              @default(120)
  // maxPuzzleImages Int              @default(30)
  isArchived     Boolean          @default(false)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  members        CoupleMember[]
  clickCounter   ClickCountTable?
  uploadedImages UploadedImage[]
  puzzleImages   PuzzleImages[]
  loveNotes      LoveNote[]
  journeyEntries JourneyEntry[]
  auditLogs      AuditLog[]
  musicTracks    MusicTrack[] // 🌟 MusicTrack အတွက် Relation အသစ်
  shortNotes     ShortNote[] // 🌟 ဒါလေး အသစ် တိုးလိုက်ပါ

  // 🌟 ဒါလေး အသစ် တိုးလိုက်ပါ (Video မတင်ရသေးတဲ့ စုံတွဲတွေအတွက် ? ခံထားပေးပါ)
  surpriseVideoUrl String?
  secretNote       String? // ဗီဒီယိုပြီးမှ ပေါ်မည့်စာ
  surpriseMessage  String? // 🌟 စာရိုက်ပြမည့်စာ (အသစ်တိုးရန်)
  pixelArt         PixelArt?
}

// 🌟 [New] Figma-style Short Notes များ သိမ်းဆည်းရန်
model ShortNote {
  id        String   @id @default(cuid())
  coupleId  String
  content   String // စာသား
  color     String   @default("bg-[#FFF3A3]") // Sticky Note အရောင်
  x         Float    @default(0) // ဘယ်ဘက်ကနေ ဘယ်လောက်ကွာလဲ
  y         Float    @default(0) // အပေါ်ကနေ ဘယ်လောက်ကွာလဲ
  reactions String   @default("") // 🌟 ဤလိုင်းလေး အသစ်တိုးပေးပါ
  createdAt DateTime @default(now())

  couple Couple @relation(fields: [coupleId], references: [id], onDelete: Cascade)

  @@index([coupleId])
}

model PixelArt {
  id        String   @id @default(cuid())
  coupleId  String   @unique
  pixels    String   @db.Text // အရောင် 256 ကွက်စာကို JSON String အနေနဲ့ သိမ်းပါမည်
  updatedAt DateTime @updatedAt

  couple Couple @relation(fields: [coupleId], references: [id], onDelete: Cascade)
}

model CoupleMember {
  id        String             @id @default(cuid())
  coupleId  String
  userId    String?
  email     String
  role      CoupleMemberRole   @default(PARTNER)
  status    CoupleMemberStatus @default(INVITED)
  canEdit   Boolean            @default(false)
  invitedAt DateTime           @default(now())
  joinedAt  DateTime?
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
  couple    Couple             @relation(fields: [coupleId], references: [id], onDelete: Cascade)
  user      User?              @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@unique([coupleId, email])
  @@unique([userId])
  @@index([coupleId]) // 🌟 [New Index] 
}

