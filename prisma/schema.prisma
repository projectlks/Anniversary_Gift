model ClickCountTable {
  id        Int      @id @default(autoincrement())
  coupleId  String?  @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // 🌟 ယခင်က ရိုးရိုး Click စနစ်
  count Int @default(0)

  // 🔥 [အသစ်] Stack (Streak) စနစ်အတွက် Fields များ
  stackCount Int @default(0) // လက်ရှိ စုဆောင်းမိသော Stack အရေအတွက်

  ownerLastClick   DateTime? // Owner (ကောင်လေး) နောက်ဆုံးနှိပ်ခဲ့သော အချိန်
  partnerLastClick DateTime? // Partner (ကောင်မလေး) နောက်ဆုံးနှိပ်ခဲ့သော အချိန်
  lastStackDate    DateTime? // (၂) ယောက်လုံးနှိပ်မိ၍ Stack တက်သွားသော နောက်ဆုံးရက် (Date Only)

  couple Couple? @relation(fields: [coupleId], references: [id], onDelete: SetNull)

  @@index([coupleId])
}

model UploadedImage {
  id          Int      @id @default(autoincrement())
  coupleId    String?
  createdById String?
  imgUrl      String
  uploadedAt  DateTime @default(now())
  isArchived  Boolean  @default(false)
  couple      Couple?  @relation(fields: [coupleId], references: [id], onDelete: SetNull)
  createdBy   User?    @relation("MemoryCreator", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([coupleId]) // 🌟 [New Index]
}

model PuzzleImages {
  id          Int      @id @default(autoincrement())
  coupleId    String?
  createdById String?
  imgUrl      String
  uploadedAt  DateTime @default(now())
  isArchived  Boolean  @default(false)
  couple      Couple?  @relation(fields: [coupleId], references: [id], onDelete: SetNull)
  createdBy   User?    @relation("PuzzleCreator", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([coupleId]) // 🌟 [New Index]
}

model LoveNote {
  id          String   @id @default(cuid())
  coupleId    String
  updatedById String?
  dateLabel   String?
  title       String   @default("My Dearest Love,")
  greeting    String   @default("My Dearest Love,")
  content     String   @default("Every moment with you is a memory I treasure forever.")
  closing     String   @default("Forever and always yours,")
  signature   String   @default("Your Beloved")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  couple      Couple   @relation(fields: [coupleId], references: [id], onDelete: Cascade)
  updatedBy   User?    @relation("NoteEditor", fields: [updatedById], references: [id], onDelete: SetNull)

  @@unique([coupleId])
  @@index([coupleId]) // 🌟 [New Index]
}

model JourneyEntry {
  id          String   @id @default(cuid())
  coupleId    String
  createdById String?
  title       String
  description String?
  eventDate   DateTime
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  couple      Couple   @relation(fields: [coupleId], references: [id], onDelete: Cascade)
  createdBy   User?    @relation("JourneyCreator", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([coupleId, eventDate]) // 🌟 [New Index] (eventDate ဖြင့် စီစဉ်မှုများရှိနိုင်၍ Composite သုံးထားသည်)
}

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String?
  coupleId   String?
  action     String
  entityType String
  entityId   String?
  details    Json?
  createdAt  DateTime @default(now())
  actor      User?    @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)
  couple     Couple?  @relation(fields: [coupleId], references: [id], onDelete: SetNull)

  @@index([coupleId, createdAt]) // 🌟 [New Index] (Log များကို အချိန်ဖြင့် ပြန်ကြည့်နိုင်ရန်)
}

// 🌟 [New] သီချင်းများ သိမ်းဆည်းရန် Table အသစ်
model MusicTrack {
  id       String   @id @default(cuid())
  coupleId String?
  name     String
  url      String
  addedAt  DateTime @default(now())
  couple   Couple?  @relation(fields: [coupleId], references: [id], onDelete: Cascade)

  @@index([coupleId, addedAt]) // 🌟 [New Index]
}

model Account {
  id                       String  @id @default(cuid())
  userId                   String
  type                     String
  provider                 String
  providerAccountId        String
  refresh_token            String? @db.Text
  access_token             String? @db.Text
  expires_at               Int?
  token_type               String?
  scope                    String?
  id_token                 String? @db.Text
  session_state            String?
  refresh_token_expires_in Int?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId]) // 🌟 [New Index]
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId]) // 🌟 [New Index]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
